# Server
PORT=3000
NODE_ENV=development

# Database (Turso/LibSQL)
TURSO_CONNECTION_URL="libsql://your-database.turso.io"
TURSO_AUTH_TOKEN="your-turso-token"

# JWT
JWT_SECRET="your-jwt-secret-min-32-characters-long"
JWT_EXPIRES_IN="7d"

# Cloudinary
CLOUDINARY_NAME="your-cloudinary-name"
CLOUDINARY_KEY="your-cloudinary-key"
CLOUDINARY_SECRET="your-cloudinary-secret"

# SMTP (Email) — Gmail (Recommended)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-digit-app-password"
SMTP_SECURE="false"
SMTP_FROM="Blog Berita <your-email@gmail.com>"

# SMTP (Email) — MailerSend (alternatif, jika pakai MailerSend)
# SMTP_HOST="smtp.mailersend.net"
# SMTP_PORT="587"
# SMTP_USER="your-mailersend-user"
# SMTP_PASS="your-mailersend-pass"
# SMTP_SECURE="false"
# SMTP_FROM="Blog Berita <noreply@yourdomain.com>"

FRONTEND_URL="http://localhost:5173"

# Upload
LIMIT_FILE_SIZE=10

# AI Provider — Gemini (default)
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.0-flash"

# AI Provider — Groq (fallback ketika Gemini error/rate limit)
# Daftar model: https://console.groq.com/docs/models
GROQ_API_KEY="gsk_your-groq-api-key"
GROQ_MODEL="llama-3.3-70b-versatile"
